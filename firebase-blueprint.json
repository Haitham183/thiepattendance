{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "System users including admins, instructors, and supervisors.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "fullName": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "instructor", "supervisor"] },
        "specialization": { "type": "string", "description": "Optional: Only for instructors" },
        "permissions": { "type": "array", "description": "List of specific privileges" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "fullName", "email", "role"]
    },
    "Specialization": {
      "title": "Specialization",
      "description": "Technical disciplines provided by the institute.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "nameEn": { "type": "string" },
        "nameAr": { "type": "string" },
        "description": { "type": "string" }
      },
      "required": ["nameEn", "nameAr"]
    },
    "Group": {
      "title": "Training Group",
      "description": "A cohort of trainees in a specific specialization.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "specializationId": { "type": "string" },
        "instructorId": { "type": "string" },
        "schedule": { "type": "object" },
        "status": { "type": "string", "enum": ["active", "completed", "pending"] },
        "startDate": { "type": "string", "format": "date" },
        "endDate": { "type": "string", "format": "date" }
      },
      "required": ["name", "specializationId", "instructorId", "status"]
    },
    "Trainee": {
      "title": "Trainee",
      "description": "Registered trainees in the institute.",
      "type": "object",
      "properties": {
        "jobId": { "type": "string" },
        "fullName": { "type": "string" },
        "companyName": { "type": "string" },
        "mobile": { "type": "string" },
        "email": { "type": "string" },
        "specializationId": { "type": "string" },
        "groupId": { "type": "string" },
        "enrollmentStart": { "type": "string", "format": "date" },
        "enrollmentEnd": { "type": "string", "format": "date" }
      },
      "required": ["jobId", "fullName", "companyName", "specializationId", "groupId"]
    },
    "Attendance": {
      "title": "Attendance Record",
      "description": "Daily attendance for a trainee.",
      "type": "object",
      "properties": {
        "traineeId": { "type": "string" },
        "groupId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["P", "A", "E", "H", "L"] },
        "markedBy": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["traineeId", "groupId", "date", "status", "markedBy"]
    },
    "Evaluation": {
      "title": "Monthly Evaluation",
      "description": "Monthly performance scores for trainees.",
      "type": "object",
      "properties": {
        "traineeId": { "type": "string" },
        "groupId": { "type": "string" },
        "month": { "type": "integer" },
        "year": { "type": "integer" },
        "score1": { "type": "number", "minimum": 0, "maximum": 100 },
        "score2": { "type": "number", "minimum": 0, "maximum": 100 },
        "average": { "type": "number" },
        "grade": { "type": "string", "enum": ["Poor", "Good", "Very Good", "Excellent"] },
        "submittedBy": { "type": "string" }
      },
      "required": ["traineeId", "groupId", "month", "year", "score1", "score2"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles and roles."
    },
    "/specializations/{specId}": {
      "schema": "Specialization",
      "description": "List of disciplines."
    },
    "/groups/{groupId}": {
      "schema": "Group",
      "description": "Training cohorts."
    },
    "/trainees/{traineeId}": {
      "schema": "Trainee",
      "description": "Trainee demographic and enrollment data."
    },
    "/attendance/{attendanceId}": {
      "schema": "Attendance",
      "description": "Individual attendance markings."
    },
    "/evaluations/{evaluationId}": {
      "schema": "Evaluation",
      "description": "Monthly scores."
    },
    "/settings/global": {
      "schema": {
        "type": "object",
        "properties": {
          "operatingHours": { "type": "object" }
        }
      },
      "description": "System settings."
    }
  }
}
